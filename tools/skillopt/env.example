# Copy this file to a private shell snippet or export the values manually.
# Do not commit real secrets.

# Recommended OpenAI-compatible mode from the SkillOpt README.
export AZURE_OPENAI_ENDPOINT="https://api.openai.com/v1"
export AZURE_OPENAI_AUTH_MODE="openai_compatible"
export AZURE_OPENAI_API_KEY="replace-with-your-api-key"

# Override these if your account exposes different model or deployment names.
export SKILLOPT_OPTIMIZER_MODEL="gpt-5.5"
export SKILLOPT_TARGET_MODEL="gpt-5.5"
