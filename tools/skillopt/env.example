# Copy this file to a private shell snippet or export the values manually.

# Default path uses local Codex CLI auth, not API keys.
export SKILLOPT_BACKEND="codex_cli"
export SKILLOPT_CODEX_BIN="codex"
export SKILLOPT_CODEX_SANDBOX="read-only"
export CODEX_EXEC_USE_SDK="cli"
export CODEX_EXEC_FULL_AUTO="false"

# Optional: leave unset to inherit your Codex CLI default model.
# export SKILLOPT_OPTIMIZER_MODEL="gpt-5.5"
# export SKILLOPT_TARGET_MODEL="gpt-5.5"

# Optional fallback: set SKILLOPT_BACKEND=openai_chat and export the
# AZURE_OPENAI_* variables documented in tools/skillopt/README.md.
