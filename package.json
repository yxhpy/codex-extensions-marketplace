{
  "name": "yxhpy-codex-extensions",
  "description": "Polished Codex/Pi marketplace for owner-agent workflows, real subagent fanout, MCP helpers, media tools, and release-grade verification.",
  "version": "0.1.23",
  "license": "MIT",
  "author": "yxhpy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yxhpy/codex-extensions-marketplace.git"
  },
  "homepage": "https://github.com/yxhpy/codex-extensions-marketplace#readme",
  "bugs": {
    "url": "https://github.com/yxhpy/codex-extensions-marketplace/issues"
  },
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package",
    "codex-plugin",
    "agent-workflows",
    "subagents",
    "mcp",
    "workflow-orchestration",
    "verification",
    "frontend",
    "grok"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test tests/*.ts plugins/codex-augment-dispatcher/tests/*.ts",
    "test:dispatcher": "node --experimental-strip-types --test plugins/codex-augment-dispatcher/tests/*.ts",
    "test:clean": "node --experimental-strip-types plugins/codex-augment-dispatcher/scripts/clean_test.ts",
    "test:docker-clean": "node --experimental-strip-types plugins/codex-augment-dispatcher/scripts/docker_clean_test.ts",
    "skillopt:install-prompts": "node tools/skillopt/install_prompts.mjs",
    "skillopt:validate": "node tools/skillopt/validate_setup.mjs",
    "skillopt:train": "node tools/skillopt/run_train.mjs",
    "skillopt:eval": "node tools/skillopt/run_eval.mjs",
    "check:reliable-agent-workflow": "node --experimental-strip-types plugins/codex-augment-dispatcher/scripts/sync_reliable_agent_workflow.ts check --remote",
    "release:check": "npm ci && node --experimental-strip-types --check plugins/codex-augment-dispatcher/scripts/dispatcher_mcp.ts && node --experimental-strip-types plugins/codex-augment-dispatcher/scripts/sync_reliable_agent_workflow.ts check --remote && npm test && node --experimental-strip-types plugins/codex-augment-dispatcher/scripts/dynamic_workflow.ts e2e --json \"Plan a subagent workflow with approval gates and end-to-end verification\" && npm run test:clean && npm run test:docker-clean"
  },
  "engines": {
    "node": ">=22.18"
  },
  "pi": {
    "skills": [
      "./plugins/codex-augment-dispatcher/skills"
    ],
    "extensions": [
      "./extensions/codex-image-gen/index.ts",
      "./extensions/xai-grok/index.ts"
    ]
  },
  "dependencies": {
    "@types/node": "^25.9.1"
  }
}
